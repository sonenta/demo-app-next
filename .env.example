# Sonenta API key (format: snt_live_<prefix>.<secret>) with `missing:write` scope.
# Bound to the public demo sandbox project (demo-public).
#
# NOT required to run the demo: the showcase overrides the missing-key transport
# client-side to visualize batches locally, and the BUILD-time server fetch
# (@sonenta/next/server getBundles) reads the PUBLIC CDN — no token needed.
# Only set these if you wire the real POST transport (-> /v1/missing).
#
# Never commit a real value. For deploys, inject from the bridge `secrets` peer.

# Read on the server at build time (App Router Server Components).
SONENTA_API_KEY=

# Exposed to the client provider (only if you enable the real transport).
NEXT_PUBLIC_SONENTA_API_KEY=
